# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (multimodal vision capable)
FASHION_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Database (SQLite default, no setup required)
FASHION_DATABASE_URL=sqlite:///./fashion.db

# Image upload directory (relative to app/api/)
FASHION_UPLOAD_DIR=uploads

# Max upload size in MB
FASHION_MAX_UPLOAD_MB=10

# Logging
FASHION_LOG_LEVEL=INFO
FASHION_DEBUG=false
